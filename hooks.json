[
  {
    "id": "stock-app-deploy",
    "execute-command": "/app/deploy.sh",
    "command-working-directory": "/app",
    "response-message": "Deploying stock app...",
    "trigger-rule": {
      "match": {
        "type": "payload-hash-sha1",
        "secret": "your-github-webhook-secret",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature"
        }
      }
    }
  }
] 